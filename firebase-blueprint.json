{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Perfis de usuários do sistema Nexus Frota",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID exclusivo do Firebase Auth" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["Master", "Gestão", "Visualizador"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "MaintenanceTask": {
      "title": "Maintenance Task",
      "description": "Ordem de serviço para o quadro Kanban",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicleId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Triagem", "Em Manutenção", "Aguardando Peças", "Finalizado"] },
        "priority": { "type": "string", "enum": ["Baixa", "Média", "Alta", "Urgente"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["vehicleId", "title", "status"]
    },
    "TelemetryLog": {
      "title": "Telemetry Log",
      "description": "Dados de performance e consumo de combustível",
      "type": "object",
      "properties": {
        "vehicleId": { "type": "string" },
        "fuelConsumption": { "type": "number", "description": "km/l" },
        "cost": { "type": "number", "description": "R$" },
        "speedAlerts": { "type": "integer" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "KanbanTask": {
      "title": "Kanban Task",
      "description": "Atividade do quadro Kanban de demandas",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "progress", "review", "done"] },
        "sector": { "type": "string" },
        "priority_color": { "type": "string" },
        "activity_type": { "type": "string" },
        "responsibles": { "type": "array" },
        "deadline": { "type": "string", "description": "Prazo de conclusão (YYYY-MM-DD)" },
        "updates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "responsible": { "type": "object" },
              "date": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "KanbanResponsible": {
      "title": "Kanban Responsible",
      "description": "Membro da equipe responsável por atividades",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "whatsapp": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "KanbanQuickTask": {
      "title": "Kanban Quick Task",
      "description": "Pendência diária urgente e prioritária para compartilhamento rápido",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "Data de inserção" },
        "description": { "type": "string", "description": "Descrição da urgência" },
        "responsible": { "type": "string", "description": "Nome do responsável" },
        "sector": { "type": "string", "description": "Setor responsável pela demanda" },
        "status": { "type": "string", "enum": ["A Fazer", "Em Andamento", "Em Revisão", "Concluído"] },
        "deadline": { "type": "string", "format": "date", "description": "Prazo acordado" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "description", "responsible", "sector", "status", "deadline"]
    },
    "KanbanQuickTaskLog": {
      "title": "Kanban Quick Task Log",
      "description": "Histórico de logs de alterações das Pendências Rápidas",
      "type": "object",
      "properties": {
        "taskId": { "type": "string" },
        "taskDescription": { "type": "string" },
        "actionType": { "type": "string", "enum": ["create", "update", "delete"] },
        "details": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["actionType", "details", "userEmail", "timestamp"]
    },
    "Indicator": {
      "title": "Indicator",
      "description": "Indicador de gestão à vista",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "section": { "type": "string" },
        "subsection": { "type": "string" },
        "unit": { "type": "string" },
        "target": { "type": "number" },
        "current_value": { "type": "number" },
        "chart_type": { "type": "string", "enum": ["gauge", "bar", "pie", "number", "line"] }
      }
    },
    "IndicatorValue": {
      "title": "Indicator Value",
      "description": "Valor mensal de um indicador",
      "type": "object",
      "properties": {
        "indicator_id": { "type": "string" },
        "month": { "type": "string" },
        "target": { "type": "number" },
        "current_value": { "type": "number" }
      }
    },
    "MachineSupplyAssignment": {
      "title": "Machine Supply Assignment",
      "description": "Vínculo de maquinário e equipamentos a abastecimentos (MAQ/GER)",
      "type": "object",
      "properties": {
        "transactionId": { "type": "string", "description": "ID da transação/abastecimento (CÓD. TRANSAÇÃO)" },
        "machineryDestination": { "type": "string", "enum": ["GERADOR PEQUENO PORTE (ATÉ 15 KVA)", "GERADOR MÉDIO PORTE (DE 15 ATÉ 75 KVA)", "GERADOR GRANDE PORTE (75 ATÉ 500 KVA)", "ROÇADEIRA(S)", "BOMBA SUBMERSA", "COMPRESSOR(ES)", "MOTOSERRA(S)", "COMPACTADOR(ES)", "CORTADOR(ES) DE GRAMA", "TORRE DE ILUMINAÇÃO", "SOPRADOR DE FOLHAS"] },
        "model": { "type": "string" },
        "property": { "type": "string", "enum": ["PRÓPRIO", "LOCADO"] },
        "tombamentoNumber": { "type": "string" },
        "userUnit": { "type": "string" },
        "updatedBy": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["transactionId", "machineryDestination", "updatedBy"]
    },
    "CalendarSelection": {
      "title": "Calendar Selection",
      "description": "Seleções de tipos de ativos feitos no dia registrados pelo usuário",
      "type": "object",
      "properties": {
        "date": { "type": "string", "description": "Data no formato YYYY-MM-DD" },
        "selectedTypes": { "type": "array", "description": "Lista de tipos de ativos selecionados para este dia" },
        "updatedBy": { "type": "string", "description": "Email do usuário que efetuou a alteração" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "selectedTypes"]
    },
    "ChecklistSubmission": {
      "title": "Checklist Submission",
      "description": "Respostas do checklist enviadas pelos motoristas/condutores",
      "type": "object",
      "properties": {
        "driverName": { "type": "string" },
        "currentUsage": { "type": "number", "description": "KM ou Horímetro atual do ativo" },
        "usagePhotoUrl": { "type": "string", "description": "Foto comprovante do KM ou Horímetro em Base64" },
        "plate": { "type": "string", "description": "Placa do ativo" },
        "assetType": { "type": "string", "description": "Tipo do ativo correspondente à aba da planilha" },
        "dateTime": { "type": "string", "format": "date-time" },
        "responses": { "type": "array" },
        "status": { "type": "string", "enum": ["completed"] }
      },
      "required": ["driverName", "currentUsage", "usagePhotoUrl", "plate", "assetType", "dateTime", "responses", "status"]
    },
    "PreventivaLocadora": {
      "title": "Preventiva Locadora",
      "description": "Dados de controle preventivo para frotas locadas",
      "type": "object",
      "properties": {
        "placa": { "type": "string", "description": "Placa do veículo sanitizada (chave)" },
        "odometroRevisao": { "type": "integer" },
        "revisaoPrevista": { "type": "integer" },
        "dataRevisao": { "type": "string", "description": "Data da última revisão (YYYY-MM-DD)" },
        "locadora": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["placa", "odometroRevisao", "revisaoPrevista", "dataRevisao", "locadora"]
    },
    "PreventivaLocadoraLog": {
      "title": "Preventiva Locadora Log",
      "description": "Logs de auditoria de alterações nos odômetros de preventivas",
      "type": "object",
      "properties": {
        "placa": { "type": "string" },
        "odometroRevisao": { "type": "integer" },
        "revisaoPrevista": { "type": "integer" },
        "dataRevisao": { "type": "string" },
        "locadora": { "type": "string" },
        "usuarioEmail": { "type": "string" },
        "usuarioNome": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "tipo": { "type": "string", "enum": ["individual", "lote"] }
      },
      "required": ["placa", "odometroRevisao", "revisaoPrevista", "dataRevisao", "locadora", "usuarioEmail", "timestamp", "tipo"]
    },
    "PreventivaEmailConfig": {
      "title": "Preventiva Email Config",
      "description": "Configuração de alertas e agendamento de e-mails para a gestão",
      "type": "object",
      "properties": {
        "locadora": { "type": "string" },
        "active": { "type": "boolean" },
        "emails": { "type": "string" },
        "frequencia": { "type": "string" },
        "horario": { "type": "string" },
        "updatedBy": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["locadora", "active", "emails", "frequencia"]
    },
    "PreventivaScheduledEmail": {
      "title": "Preventiva Scheduled Email",
      "description": "Lista de e-mails de alerta pendentes de envio ou já enviados",
      "type": "object",
      "properties": {
        "placa": { "type": "string" },
        "modelo": { "type": "string" },
        "odometroAtual": { "type": "integer" },
        "odometroRevisao": { "type": "integer" },
        "revisaoPrevista": { "type": "integer" },
        "odometroProximaRevisao": { "type": "integer" },
        "porcentagemUso": { "type": "integer" },
        "destinatarios": { "type": "array" },
        "frequencia": { "type": "string" },
        "envioAgendadoPara": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Agendado", "Enviado"] },
        "locadora": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "subject": { "type": "string" },
        "body": { "type": "string" }
      },
      "required": ["placa", "modelo", "status", "locadora", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Dados de perfil do usuário"
    },
    "/maintenance_tasks/{taskId}": {
      "schema": "MaintenanceTask",
      "description": "Ordens de serviço para o Kanban"
    },
    "/telemetry_logs/{logId}": {
      "schema": "TelemetryLog",
      "description": "Logs de telemetria para BI"
    },
    "/kanban_tasks/{taskId}": {
      "schema": "KanbanTask",
      "description": "Atividades CGF"
    },
    "/kanban_responsibles/{responsibleId}": {
      "schema": "KanbanResponsible",
      "description": "Equipe CGF"
    },
    "/kanban_quick_tasks/{taskId}": {
      "schema": "KanbanQuickTask",
      "description": "Lista rápida de pendências diárias urgentes"
    },
    "/kanban_quick_tasks_logs/{logId}": {
      "schema": "KanbanQuickTaskLog",
      "description": "Histórico de logs de alterações das Pendências Rápidas"
    },
    "/indicators/{indicatorId}": {
      "schema": "Indicator",
      "description": "Definições de indicadores"
    },
    "/indicator_values/{valueId}": {
      "schema": "IndicatorValue",
      "description": "Valores mensais de indicadores"
    },
    "/machine_supply_assignments/{assignmentId}": {
      "schema": "MachineSupplyAssignment",
      "description": "Preenchimento de dados de maquinário para abastecimentos"
    },
    "/calendar_selections/{selectionId}": {
      "schema": "CalendarSelection",
      "description": "Seleções de tipos de ativos feitos no dia pelo usuário"
    },
    "/checklist_submissions/{submissionId}": {
      "schema": "ChecklistSubmission",
      "description": "Checklists preenchidos pelos condutores"
    },
    "/preventiva_locadoras/{docId}": {
      "schema": "PreventivaLocadora",
      "description": "Controle preventivo por placa"
    },
    "/preventiva_locadora_logs/{logId}": {
      "schema": "PreventivaLocadoraLog",
      "description": "Histórico de auditoria de alterações por locadora"
    },
    "/preventiva_email_configs/{configId}": {
      "schema": "PreventivaEmailConfig",
      "description": "Configurações de alerta e e-mail por locadora"
    },
    "/preventiva_scheduled_emails/{notificationId}": {
      "schema": "PreventivaScheduledEmail",
      "description": "Histórico e agendamento de e-mails cadastrados em status Pendente"
    }
  }
}
