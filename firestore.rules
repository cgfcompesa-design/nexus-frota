rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function hasRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return hasRole('Master') || request.auth.token.email == 'cgf.compesa@gmail.com';
    }

    function isGestor() {
      return hasRole('Gestão') || isAdmin();
    }

    // --- Users ---
    match /users/{userId} {
      // Permitir que qualquer usuário autenticado veja seu próprio perfil ou que administradores vejam qualquer perfil
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Permitir listagem de usuários apenas para administradores
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && 
        incoming().keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
        incoming().role == 'Visualizador' && // Default role for new users
        incoming().uid == request.auth.uid;
        
      allow update: if isAdmin() || (isOwner(userId) && 
        !incoming().diff(existing()).affectedKeys().hasAny(['role', 'email', 'uid']));
    }

    // --- Maintenance Tasks ---
    match /maintenance_tasks/{taskId} {
      allow read: if isSignedIn();
      allow create, update: if isGestor() || hasRole('Operador') || hasRole('Gestão'); // Keeping Operador if it existed but using Gestão
      allow delete: if isAdmin() || isGestor();
    }

    // --- Telemetry Logs ---
    match /telemetry_logs/{logId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGestor();
    }

    // --- Kanban System ---
    match /kanban_tasks/{taskId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /kanban_responsibles/{responsibleId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // --- Indicators ---
    match /indicators/{indicatorId} {
      allow read: if isSignedIn();
      allow write: if isGestor();
    }

    match /indicator_values/{valueId} {
      allow read: if isSignedIn();
      allow write: if isGestor();
    }

    // Connection test
    match /test/connection {
      allow read: if true;
    }
  }
}
